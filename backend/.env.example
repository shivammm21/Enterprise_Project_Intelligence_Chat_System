# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/knowledge_assistant

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider - auto-detected from whichever key is set below.
# Set OPENAI_API_KEY to use OpenAI, or GOOGLE_API_KEY to use Gemini.
# If both are set, OpenAI takes priority.
# AI_PROVIDER is no longer needed.

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Gemini
GOOGLE_API_KEY=your-google-api-key

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Admin seed account (auto-created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-admin-password
ADMIN_NAME=Admin
